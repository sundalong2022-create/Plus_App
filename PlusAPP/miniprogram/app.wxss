page {
  background: #f4f7fb;
  color: #182031;
  font-size: 28rpx;
}

button::after {
  border: 0;
}

button {
  margin: 0;
  padding: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 56rpx;
  box-sizing: border-box;
}

.section-stack > view,
.section-stack > button,
.section-stack > ui-panel {
  margin-bottom: 24rpx;
}

.section-stack > view:last-child,
.section-stack > button:last-child,
.section-stack > ui-panel:last-child {
  margin-bottom: 0;
}

.hero-banner {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 30rpx 26rpx;
  background: linear-gradient(135deg, #fff2d8 0%, #ffffff 58%, #eef8ff 100%);
  box-shadow: 0 12rpx 28rpx rgba(34, 44, 68, 0.08);
}

.hero-top {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #182031;
}

.hero-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #566174;
}

.hero-progress-row,
.section-header,
.metric-row,
.list-row,
.task-card-head,
.task-card-row,
.list-row-tight {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.hero-progress-row {
  margin-top: 24rpx;
  margin-bottom: 12rpx;
}

.auth-banner {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border: 2rpx solid transparent;
}

.auth-banner-warm {
  background: rgba(255, 244, 223, 0.92);
  border-color: #ffe0a7;
}

.auth-banner-mint {
  background: rgba(232, 249, 241, 0.92);
  border-color: #cbead9;
}

.auth-banner-sky {
  background: rgba(233, 243, 255, 0.92);
  border-color: #d2e5ff;
}

.auth-banner-coral {
  background: rgba(255, 239, 234, 0.96);
  border-color: #ffd4c6;
}

.auth-banner-neutral {
  background: rgba(239, 242, 247, 0.95);
  border-color: #e2e7ef;
}

.auth-copy {
  min-width: 0;
  flex: 1;
}

.auth-banner-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #182031;
}

.auth-banner-text {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #556176;
}

.auth-retry-btn {
  flex-shrink: 0;
  min-width: 144rpx;
}

.hero-progress-label,
.hero-note,
.metric-note,
.list-note {
  font-size: 24rpx;
  color: #647086;
}

.hero-foot {
  margin-top: 20rpx;
}

.hero-stat-grid,
.metric-grid,
.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.hero-stat-card,
.metric-card {
  border-radius: 18rpx;
  padding: 18rpx 16rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 2rpx solid rgba(255, 255, 255, 0.65);
}

.hero-stat-label,
.metric-label {
  display: block;
  font-size: 22rpx;
  color: #647086;
  margin-bottom: 10rpx;
}

.hero-stat-value,
.metric-value {
  display: block;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #182031;
}

.progress {
  height: 16rpx;
  border-radius: 999rpx;
  background: #e6ebf2;
  overflow: hidden;
}

.progress-large {
  height: 18rpx;
}

.progress-bar {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #ff9b37 0%, #0d8e69 100%);
  background-size: 180% 100%;
  transition: width 520ms cubic-bezier(0.22, 1, 0.36, 1);
  animation: progress-shift 2.8s linear infinite;
}

.star-strip,
.tag-row,
.pill-row,
.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.star-node {
  min-width: 62rpx;
  height: 62rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #edf0f5;
  color: #7c8699;
  box-sizing: border-box;
  font-size: 24rpx;
  font-weight: 600;
}

.star-node-active {
  background: #ffebcc;
  color: #8f5600;
  animation: star-soft-pop 520ms ease;
}

.star-node-current {
  border: 2rpx solid #0d8e69;
  animation: star-ring 2.2s ease-in-out infinite;
}

.star-node-recent {
  animation: star-celebrate 1.2s cubic-bezier(0.2, 0.9, 0.2, 1);
}

.section-title {
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #182031;
}

.section-subtitle,
.muted {
  color: #6c7488;
  font-size: 24rpx;
}

.task-list,
.list-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.task-card,
.list-item,
.action-tile,
.rhyme-card,
.match-card,
.option-tile,
.track-step {
  border-radius: 20rpx;
  box-sizing: border-box;
}

.task-card {
  padding: 20rpx 18rpx;
  background: #f7f9fc;
  border: 2rpx solid #ebeff5;
}

.task-card-warm {
  background: #fff6e8;
  border-color: #ffe1ad;
}

.task-card-mint {
  background: #eff9f5;
  border-color: #cceede;
}

.task-card-sky {
  background: #eef6ff;
  border-color: #d3e6ff;
}

.task-card-coral {
  background: #fff0eb;
  border-color: #ffd8cb;
}

.task-card-copy {
  flex: 1;
  min-width: 0;
}

.task-card-title,
.list-item-title,
.metric-title {
  display: block;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #182031;
}

.task-card-subtitle,
.list-item-subtitle,
.metric-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: #6c7488;
}

.task-card-meta {
  font-size: 22rpx;
  color: #6c7488;
}

.primary-btn,
.secondary-btn,
.ghost-btn,
.action-tile,
.option-tile,
.match-card {
  min-height: 92rpx;
  border-radius: 18rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 700;
  transition: transform 160ms ease, box-shadow 160ms ease, opacity 160ms ease, filter 160ms ease;
}

.primary-btn {
  background: linear-gradient(90deg, #ff9b37 0%, #ff7f2f 100%);
  color: #ffffff;
}

.secondary-btn {
  background: #0d8e69;
  color: #ffffff;
}

.ghost-btn {
  background: #ffffff;
  color: #0d8e69;
  border: 2rpx solid #cfe8de;
}

.ghost-btn-small,
.chip {
  min-height: 74rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.button-hover {
  transform: scale(0.98);
  filter: brightness(0.98);
}

.tile-hover {
  transform: translateY(-4rpx) scale(0.99);
  box-shadow: 0 16rpx 30rpx rgba(34, 44, 68, 0.12);
}

.option-hover {
  transform: scale(0.98);
  border-color: #ffba67;
  background: #fff8ee;
}

.card-hover {
  transform: scale(0.985);
  box-shadow: 0 16rpx 26rpx rgba(34, 44, 68, 0.12);
}

.action-grid {
  margin-top: 0;
}

.action-tile {
  min-height: 176rpx;
  padding: 22rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.action-tile-warm {
  background: #fff5e3;
  border: 2rpx solid #ffe1b2;
}

.action-tile-mint {
  background: #eefaf6;
  border: 2rpx solid #d4efe4;
}

.action-tile-sky {
  background: #eef6ff;
  border: 2rpx solid #d7e8ff;
}

.action-tile-coral {
  background: #fff0eb;
  border: 2rpx solid #ffd8cb;
}

.action-tile-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #182031;
}

.action-tile-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #5d6880;
}

.config-stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.config-block {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.config-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #182031;
}

.config-value,
.config-note,
.config-tip-item {
  font-size: 24rpx;
  line-height: 1.6;
  color: #5d6880;
}

.config-input {
  min-height: 92rpx;
  border-radius: 18rpx;
  border: 2rpx solid #d9e1ec;
  background: #f8fbff;
  box-sizing: border-box;
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  color: #182031;
}

.config-button-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.config-tips {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.status-card {
  border-radius: 18rpx;
  padding: 22rpx 20rpx;
  border: 2rpx solid transparent;
}

.status-card-warm {
  background: #fff5e3;
  border-color: #ffe1b2;
}

.status-card-mint {
  background: #eefaf6;
  border-color: #d4efe4;
}

.status-card-coral {
  background: #fff0eb;
  border-color: #ffd8cb;
}

.status-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #182031;
}

.status-copy {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #5d6880;
}

.formula-stage {
  border-radius: 24rpx;
  padding: 28rpx 22rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  border: 2rpx solid #ebf0f7;
}

.formula-eyebrow {
  display: block;
  font-size: 22rpx;
  color: #6c7488;
  text-align: center;
}

.formula {
  display: block;
  font-size: 58rpx;
  line-height: 1.15;
  font-weight: 700;
  text-align: center;
  color: #182031;
  margin: 18rpx 0 14rpx;
}

.formula-caption {
  display: block;
  text-align: center;
  font-size: 26rpx;
  line-height: 1.5;
  color: #5d6880;
}

.dot-groups {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 22rpx;
}

.dot-group {
  display: flex;
  gap: 10rpx;
  padding: 12rpx 14rpx;
  border-radius: 999rpx;
  background: #eef6ff;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #0d8e69;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-row,
.list-row {
  display: flex;
  gap: 14rpx;
  padding: 16rpx 0;
  border-bottom: 2rpx solid rgba(108, 116, 136, 0.08);
}

.tip-row:last-child,
.list-row:last-child {
  border-bottom: 0;
}

.tip-bullet {
  width: 14rpx;
  height: 14rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #ff9b37;
  flex-shrink: 0;
}

.tip-copy {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.6;
  color: #243147;
}

.rhyme-grid,
.match-grid,
.answer-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.rhyme-card {
  padding: 20rpx 18rpx;
  background: #f8fbff;
  border: 2rpx solid #e8eef7;
}

.rhyme-card-formula {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #182031;
}

.rhyme-card-text {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #647086;
}

.rhyme-card-answer {
  display: inline-flex;
  margin-top: 14rpx;
  min-width: 52rpx;
  height: 52rpx;
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  background: #ffebcc;
  color: #8f5600;
  font-size: 24rpx;
  font-weight: 700;
}

.question-stage {
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(34, 44, 68, 0.08);
}

.question-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.question-prompt {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #6c7488;
}

.answer-grid {
  margin-top: 28rpx;
}

.option-tile {
  min-height: 116rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: #f7f9fc;
  border: 2rpx solid #e7edf5;
  font-size: 34rpx;
  font-weight: 700;
  color: #182031;
}

.option-tile-selected {
  background: #fff2df;
  border-color: #ffba67;
  color: #9d5d01;
}

.feedback-banner {
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  animation: feedback-rise 360ms cubic-bezier(0.2, 0.9, 0.2, 1);
}

.feedback-correct {
  background: #e9f8f1;
  color: #106e51;
}

.feedback-wrong {
  background: #fff0eb;
  color: #a14735;
}

.feedback-soft {
  background: #fff7e8;
  color: #8f5600;
}

.track-row {
  display: grid;
  gap: 12rpx;
}

.track-step {
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #edf1f6;
  color: #7b8598;
  font-size: 24rpx;
  font-weight: 700;
}

.track-step-active {
  background: #e8f7f2;
  color: #0d8e69;
}

.track-step-current {
  border: 2rpx solid #ff9b37;
}

.match-card {
  min-height: 200rpx;
  padding: 24rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border: 2rpx solid #e7edf5;
  box-shadow: 0 8rpx 18rpx rgba(34, 44, 68, 0.05);
}

.match-card-open {
  background: #fff7e8;
  border-color: #ffcf8c;
}

.match-card-matched {
  background: #eefaf6;
  border-color: #cceede;
}

.match-card-text {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #182031;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.summary-card {
  padding: 20rpx 16rpx;
  border-radius: 18rpx;
  background: #f7f9fc;
  border: 2rpx solid #e8edf4;
  text-align: center;
  transition: transform 180ms ease, box-shadow 180ms ease;
}

.summary-value {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #182031;
}

.summary-label {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #677287;
}

.answer-badge-row {
  display: flex;
  justify-content: center;
  margin-bottom: 18rpx;
}

.answer-badge {
  min-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  animation: badge-pop 360ms cubic-bezier(0.18, 0.92, 0.3, 1.1);
}

.answer-badge-correct {
  background: #e8f8f0;
  color: #0d7a58;
}

.answer-badge-wrong {
  background: #fff0eb;
  color: #a14735;
}

.calendar-row {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 12rpx;
}

.calendar-node {
  padding: 14rpx 8rpx 12rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.68);
  border: 2rpx solid rgba(228, 234, 244, 0.9);
  text-align: center;
  transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
}

.calendar-node-done {
  background: #fff4df;
  border-color: #ffd18d;
  box-shadow: 0 10rpx 18rpx rgba(255, 155, 55, 0.16);
}

.calendar-node-current {
  border-color: #0d8e69;
  box-shadow: 0 10rpx 18rpx rgba(13, 142, 105, 0.12);
}

.calendar-node-recent {
  animation: calendar-light 1.2s cubic-bezier(0.2, 0.9, 0.2, 1);
}

.calendar-label {
  display: block;
  font-size: 20rpx;
  color: #6c7488;
}

.calendar-value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1d2a3f;
}

.calendar-note {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #7b8598;
}

.list-item {
  padding: 18rpx 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  border-bottom: 2rpx solid rgba(108, 116, 136, 0.08);
}

.list-item:last-child {
  border-bottom: 0;
}

.list-item-copy {
  flex: 1;
  min-width: 0;
}

.list-item-tail {
  flex-shrink: 0;
  text-align: right;
}

.footer-actions,
.button-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.center {
  text-align: center;
}

.empty {
  padding: 48rpx 0;
  text-align: center;
  color: #7b8294;
}

@keyframes progress-shift {
  0% {
    background-position: 0% 50%;
  }
  100% {
    background-position: 100% 50%;
  }
}

@keyframes badge-pop {
  0% {
    opacity: 0;
    transform: translateY(10rpx) scale(0.82);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes feedback-rise {
  0% {
    opacity: 0;
    transform: translateY(10rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes star-soft-pop {
  0% {
    transform: scale(0.88);
  }
  70% {
    transform: scale(1.04);
  }
  100% {
    transform: scale(1);
  }
}

@keyframes star-ring {
  0%,
  100% {
    box-shadow: 0 0 0 0 rgba(13, 142, 105, 0.18);
  }
  50% {
    box-shadow: 0 0 0 10rpx rgba(13, 142, 105, 0);
  }
}

@keyframes star-celebrate {
  0% {
    transform: scale(0.84);
    box-shadow: 0 0 0 0 rgba(255, 155, 55, 0.28);
  }
  55% {
    transform: scale(1.08);
    box-shadow: 0 0 0 14rpx rgba(255, 155, 55, 0);
  }
  100% {
    transform: scale(1);
  }
}

@keyframes calendar-light {
  0% {
    transform: scale(0.9);
    box-shadow: 0 0 0 0 rgba(255, 155, 55, 0.28);
  }
  55% {
    transform: scale(1.05);
    box-shadow: 0 0 0 16rpx rgba(255, 155, 55, 0);
  }
  100% {
    transform: scale(1);
  }
}
