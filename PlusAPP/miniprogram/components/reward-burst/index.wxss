.reward-mask {
  position: fixed;
  inset: 0;
  z-index: 1200;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(24, 32, 49, 0.2);
  pointer-events: none;
}

.reward-burst {
  position: relative;
  width: 420rpx;
  height: 420rpx;
}

.reward-card {
  position: absolute;
  inset: 74rpx;
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(12rpx);
  box-shadow: 0 20rpx 40rpx rgba(34, 44, 68, 0.18);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  animation: reward-card-pop 560ms cubic-bezier(0.2, 0.8, 0.2, 1);
}

.reward-badge {
  display: inline-flex;
  min-height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #9c5a00;
  background: #ffeed3;
  margin-bottom: 16rpx;
}

.reward-title {
  display: block;
  font-size: 38rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #182031;
}

.reward-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #606b80;
}

.reward-orbit {
  position: absolute;
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  animation: reward-float 1.2s ease-out infinite;
}

.reward-warm .reward-orbit {
  background: linear-gradient(180deg, #ffc669 0%, #ff8a00 100%);
}

.reward-mint .reward-orbit {
  background: linear-gradient(180deg, #6de0ba 0%, #0d8e69 100%);
}

.reward-coral .reward-orbit {
  background: linear-gradient(180deg, #ffb29c 0%, #df6b4f 100%);
}

.reward-sky .reward-orbit {
  background: linear-gradient(180deg, #9fd0ff 0%, #3977d6 100%);
}

.reward-orbit-1 {
  top: 24rpx;
  left: 188rpx;
  animation-delay: 0ms;
}

.reward-orbit-2 {
  top: 86rpx;
  right: 24rpx;
  animation-delay: 120ms;
}

.reward-orbit-3 {
  bottom: 84rpx;
  right: 36rpx;
  animation-delay: 240ms;
}

.reward-orbit-4 {
  bottom: 24rpx;
  left: 182rpx;
  animation-delay: 360ms;
}

.reward-orbit-5 {
  bottom: 100rpx;
  left: 32rpx;
  animation-delay: 480ms;
}

.reward-orbit-6 {
  top: 100rpx;
  left: 28rpx;
  animation-delay: 600ms;
}

@keyframes reward-card-pop {
  0% {
    opacity: 0;
    transform: scale(0.72) translateY(18rpx);
  }
  100% {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

@keyframes reward-float {
  0% {
    opacity: 0;
    transform: scale(0.6) translateY(18rpx);
  }
  30% {
    opacity: 1;
  }
  100% {
    opacity: 0;
    transform: scale(1.18) translateY(-24rpx);
  }
}
